generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int            @id @default(autoincrement())
  username  String         @db.VarChar(255) //This is full name of user
  email     String?        @unique @db.VarChar(255)
  phone     String         @unique @db.VarChar(15)
  password  String         @db.VarChar(255)
  role      Role
  createAt  DateTime       @default(now())
  updateAt  DateTime       @updatedAt
  orderData UserDataOrder?
  sessions  Session[]
  cart      Cart?
}

model Session {
  id         Int       @id @default(autoincrement())
  userId     Int
  createAt   DateTime  @default(now())
  updateAt   DateTime  @updatedAt
  refreshAt  DateTime  @default(now())
  expires    DateTime
  revokedAt  DateTime?
  dataDevice Json      @db.JsonB

  refreshToken RefreshToken[]
  user         User           @relation(fields: [userId], references: [id], map: "Session_userId_relation")

  @@index([userId], map: "Session_userId_fkey")
}

model RefreshToken {
  id           String   @id @default(uuid())
  refreshToken String   @unique @db.VarChar(255)
  revoked      Boolean  @default(false)
  userId       Int
  expires      DateTime
  sessionId    Int
  createAt     DateTime @default(now())
  updateAt     DateTime @updatedAt
  session      Session  @relation(fields: [sessionId], references: [id], map: "RefreshToken_sessionId_relation")

  @@index([userId], map: "RefreshToken_userId_fkey")
}

model UserDataOrder {
  id     Int     @id @default(autoincrement())
  userId Int     @unique
  user   User    @relation(fields: [userId], references: [id], map: "UserData_userId_relation")
  orders Order[]
}

model Product {
  id          Int            @id @default(autoincrement())
  name        String         @db.VarChar(255)
  unit        String         @db.VarChar(50)
  price       Float
  createAt    DateTime       @default(now())
  updateAt    DateTime       @updatedAt
  type        TypeProduct
  sku         String         @db.VarChar(100) //Mã sản phẩm nội bộ
  status      String         @db.VarChar(50) //active/inactive
  mediaList   ProductMedia[]
  cartItem    Cartitem[]
  orderDetail OrderDetail[]
  batch       Batch[]
}

model Cart {
  id            Int        @id @default(autoincrement())
  totalQuantity Int        @db.SmallInt
  checkoutUrl   String     @db.Text
  cartItem      Cartitem[]
  userId        Int        @unique
  user          User       @relation(fields: [userId], references: [id], map: "Cart_userId_relation")
}

model Cartitem {
  quantity  Int     @db.SmallInt
  productId Int
  cartId    Int
  cart      Cart    @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@id([productId, cartId])
  @@index([cartId], map: "cartItem_cartId_fkey")
}

model InventoryLot {
  id           Int   @id @default(autoincrement())
  batch_Id     Int
  qty_on_hand  Int
  qty_reserved Int
  batch        Batch @relation(fields: [batch_Id], references: [id])

  @@index([batch_Id], map: "inventoryLot_batch_Id_fkey")
}

model HistoryInventory {
  id         Int      @id @default(autoincrement())
  batch_Id   Int
  type       String   @db.VarChar(20) //ENUM('IN','OUT','RETURN_IN','RETURN_OUT','ADJUST')
  qty        Int
  ref_type   String   @db.VarChar(20) //ENUM('PURCHASE','SALE','SUPPLIER_RETURN','CUSTOMER_RETURN','MANUAL')
  ref_id     Int?
  created_at DateTime @default(now())
  batch      Batch    @relation(fields: [batch_Id], references: [id])
}

model ProductMedia {
  productId Int
  mediaId   Int
  product   Product @relation(fields: [productId], references: [id])
  media     Media   @relation(fields: [mediaId], references: [id])

  @@id([productId, mediaId])
  @@index([mediaId], map: "productMedia_mediaId_fkey")
}

model Media {
  id           Int            @id @default(autoincrement())
  url          String         @db.Text
  altText      String         @db.VarChar(255)
  width        Int
  height       Int
  type         String
  productMedia ProductMedia[]
  img          Img[]
}

model Batch {
  id               Int                @id @default(autoincrement())
  supplier_name    String             @db.VarChar(100)
  nation           String             @db.VarChar(50)
  expire_date      DateTime
  import_price     Float
  import_date      DateTime
  productId        Int
  product          Product            @relation(fields: [productId], references: [id], onDelete: NoAction, map: "batch_productId_relation")
  inventoryLot     InventoryLot[]
  historyInventory HistoryInventory[]
}

model Order {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  Total         Float
  AddressRecive String         @db.VarChar(255)
  TypePay       String         @db.VarChar(15)
  osId          Int
  OrderStatus   Orderstatus    @relation(fields: [osId], references: [id], map: "order_osId_relation")
  NameRecive    String         @db.VarChar(255)
  PhoneRecive   String         @db.VarChar(15)
  userId        Int?
  userData      UserDataOrder? @relation(fields: [userId], references: [userId], map: "order_userId_relation")
  orderDetail   OrderDetail[]

  @@index([osId], map: "order_osId_fkey")
}

model OrderDetail {
  oderId      Int
  productId   Int
  quantity    Int
  price_sale  Float
  productSale Product @relation(fields: [productId], references: [id], map: "orderDetail_productId_relation")
  order       Order   @relation(fields: [oderId], references: [id])

  @@id([oderId, productId], name: "idDetail")
  @@index([productId], map: "orderDetail_productId_fkey")
}

model Orderstatus {
  id     Int     @id @default(autoincrement())
  name   String
  nameEn String
  order  Order[]
}

model Img {
  mediaId Int   @id @default(autoincrement())
  blogId  Int
  blog    Blog  @relation(fields: [blogId], references: [id])
  media   Media @relation(fields: [mediaId], references: [id])
}

model Blog {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String   @db.Text
  state     String
  image     Img[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  admin
  staff
  customer
}

enum TypeProduct {
  herb
  medicine
}
