generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id       Int      @id @default(autoincrement())
  username String   @db.VarChar(255)
  email    String   @unique @db.VarChar(255)
  password String   @db.VarChar(255)
  role     Role
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt
}

model product {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(255)
  handle        String
  stored        Int
  unit          String        @db.VarChar(50)
  price         Float
  howPack       String
  ingredient    String        @db.VarChar(255)
  typeUse       String
  destination   String
  dosage        String
  typeProductId Int
  cartItem      cartitem[]
  orderDetail   orderDetail[]
  mediaList     media[]
  typeProduct   typeproduct   @relation(fields: [typeProductId], references: [id])
  createAt      DateTime      @default(now())
  updateAt      DateTime      @updatedAt

  @@index([typeProductId], map: "product_typeProductId_fkey")
}

model groupproducttoproduct {
  A Int
  B Int

  @@unique([A, B], map: "_groupProductToproduct_AB_unique")
  @@index([B], map: "_groupProductToproduct_B_index")
  @@map("_groupproducttoproduct")
}

model cart {
  id            Int        @id @default(autoincrement())
  totalQuantity Int        @db.SmallInt
  checkoutUrl   String     @db.Text
  cartItem      cartitem[]
}

model cartitem {
  quantity  Int     @db.TinyInt
  productId Int
  cartId    Int
  cart      cart    @relation(fields: [cartId], references: [id])
  product   product @relation(fields: [productId], references: [id])

  @@id([productId, cartId])
  @@index([cartId], map: "cartItem_cartId_fkey")
}

model depotform {
  id       Int               @id @default(autoincrement())
  createAt DateTime          @default(now())
  Sup_ID   Int
  supplier supplier          @relation(fields: [Sup_ID], references: [id])
  dfd      depotformdetail[]

  @@index([Sup_ID], map: "depotForm_Sup_ID_fkey")
}

model depotformdetail {
  dF_id     Int
  productId Int
  quantity  Int
  unit      String
  price     Float
  depotForm depotform @relation(fields: [dF_id], references: [id])

  @@id([dF_id, productId])
  @@index([productId], map: "depotFormDetail_productId_fkey")
}

model groupproduct {
  id   Int    @id @default(autoincrement())
  name String
}

model media {
  id        Int     @id @default(autoincrement())
  url       String  @db.VarChar(100)
  altText   String  @db.VarChar(255)
  width     Int
  height    Int
  type      String
  productId Int
  product   product @relation(fields: [productId], references: [id], onDelete: NoAction)

  @@index([productId], map: "media_productId_fkey")
}

model supplier {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(100)
  address    String      @db.VarChar(255)
  nation     String      @db.VarChar(50)
  description String      @db.VarChar(255)
  depotForm  depotform[]
}

model typeproduct {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String    @db.Text
  products    product[]
}

model order {
  id            Int           @id @default(autoincrement())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Total         Float
  AddressRecive String        @db.VarChar(255)
  TypePay       String        @db.VarChar(15)
  osId          Int
  OrderStatus   orderstatus   @relation(fields: [osId], references: [id])
  NameRecive    String        @db.VarChar(255)
  PhoneRecive   String        @db.VarChar(15)
  orderDetail   orderDetail[]

  @@index([osId], map: "order_osId_fkey")
}

model orderDetail {
  oderId      Int
  productId   Int
  quantity    Int
  productSale product @relation(fields: [productId], references: [id])
  order       order   @relation(fields: [oderId], references: [id])

  @@id([oderId, productId], name: "idDetail")
  @@index([productId], map: "orderDetail_productId_fkey")
}

model orderstatus {
  id     Int     @id @default(autoincrement())
  name   String
  nameEn String
  Order  order[]
}
model img{
  id        Int     @id @default(autoincrement())
  url       String  @db.VarChar(100)
  altText   String  @db.VarChar(255)
  width     Int
  height    Int
  blogId Int
  blog blog @relation(fields: [blogId], references: [id])
}
model blog{
  id Int @id @default(autoincrement())
  title String @db.VarChar(255)
  content String @db.Text
  state String
  image img[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
//Thêm Blog
enum Role {
  admin
  staff
  customer
}
